{
  "name": "keystone-wasm",
  "version": "1.0.4",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/CzBiX/disasm-web.git",
    "directory": "packages/keystone"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "pnpm rollup -c && pnpm run build:types",
    "build:types": "tsup src --dts src/index.ts --dts-only",
    "dev": "tsc -w",
    "test": "vitest",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "catalog:",
    "@rollup/plugin-swc": "catalog:",
    "@rollup/plugin-typescript": "catalog:",
    "@rollup/plugin-url": "catalog:",
    "@swc/core": "catalog:",
    "rollup": "catalog:",
    "tsup": "catalog:"
  },
  "files": [
    "dist"
  ]
}
