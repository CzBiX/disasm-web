{
  "private": true,
  "name": "playground",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@vueuse/core": "^13.0.0",
    "capstone-wasm": "1.0.3",
    "keystone-wasm": "1.0.4",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.8",
    "@unocss/preset-icons": "^66.1.0",
    "@unocss/reset": "^66.1.0",
    "@unocss/transformer-variant-group": "^66.1.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "unocss": "^66.1.0",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.0.0"
  }
}
